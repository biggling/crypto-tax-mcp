PORT=3001
DB_PATH=./data/tax.db
COINGECKO_API_KEY=your_demo_api_key_here

# Polar.sh billing (configure after VPS deploy)
# Get webhook secret: Polar Dashboard → Webhooks → endpoint → Secret
POLAR_WEBHOOK_SECRET=whsec_replace_with_your_polar_webhook_secret
# Get product IDs: Polar Dashboard → Products → copy ID column
POLAR_PRODUCT_PRO=replace_with_polar_product_id_for_19_plan
POLAR_PRODUCT_TAX=replace_with_polar_product_id_for_49_plan
# Get API token: Polar Dashboard → Settings → Developers → API Tokens
# Used to PATCH subscriber portal metadata with their API key after checkout
POLAR_API_TOKEN=replace_with_your_polar_api_token
